NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
API_SECRET_KEY=your-random-secret-32-chars-here

# Zerodha Kite Connect (optional — enables live equity + MF data, free Personal API)
# 1. Register a Personal app at kite.trade/developers (free)
# 2. Set redirect URL to: https://your-domain.com/api/kite/callback
# 3. Add your api_key and api_secret below, then visit /api/kite/connect to authenticate
# Access tokens expire daily — click "Connect Zerodha" on the wealth page each day to re-auth
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
# Optional: set a static access_token to bypass OAuth (useful for quick local testing)
# ZERODHA_ACCESS_TOKEN=

# CoinDCX (optional — enables live crypto portfolio)
# Free API keys at https://coindcx.com/api
COINDCX_API_KEY=
COINDCX_API_SECRET=

# IND Money (optional — enables live foreign equity / US stocks)
# No manual keys needed — uses OAuth 2.1 PKCE via mcp.indmoney.com
# Visit /api/indmoney/connect in your browser to authenticate.
# Client credentials are auto-registered and stored in Supabase.
